# ==========================================
# Frontend Environment Variables (Vite)
# ==========================================
# Variables prefixed with VITE_ are automatically injected into the React app at build time.

# API Base URL
# - In local development: Usually "http://localhost:8000" if you aren't using Vite's proxy,
#   or "" (empty string) if you are letting Vite proxy it.
# - In production (NREC): Set this to the public URL of your server (e.g., "https://158.37.63.48")
#   OR leave it empty ("") to use relative paths so Nginx handles the routing automatically.
VITE_API_URL=http://localhost:8000

# Keycloak URL
# - In local development: "http://localhost:8080/auth"
# - In production (NREC): "https://158.37.63.48/auth" (or empty string "" to use relative paths)
VITE_KEYCLOAK_URL=http://localhost:8080/auth
